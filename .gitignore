# Python virtualenv (large, regenerable from solver/uv.lock)
solver/.venv/

# Python caches
__pycache__/
*.pyc

# Generated/regenerable artifacts (fitted weights, logs)
solver/*.npy
solver/*.log

# iPhone-capture artifacts — screenshots/captures are debug output;
# ocr/tap/wininfo are binaries built from the *.swift sources via build.sh
solver/iphone_data/captures/
solver/iphone_data/runs/
solver/iphone_data/*.png
solver/iphone_data/ocr
solver/iphone_data/ocrserve
solver/iphone_data/tap
solver/iphone_data/wininfo

# compiled C engine (built from solver/fast_engine.c)
solver/fast_engine.so

# generated HTML galleries (regenerable from their *.py generators)
solver/iphone_data/botdiff.html
solver/iphone_data/ocr_audit.html
solver/iphone_data/digit_grids.html
solver/iphone_data/digit_grids_hi.html
solver/iphone_data/double_digit_ocr.html

# regenerable image crops for the double-digit OCR audit
solver/iphone_data/dd_crops/

# recorded scratch board snapshots (g* filenames are overwritten across runs)
solver/iphone_data/g[0-9]*.json

# iPhone-Mirroring window-geometry cache (machine-local)
solver/iphone_data/.wincache

# grabbed phone board (generated by grab_board.py / server.py's /grab)
solver/iphone_data/imported_board.json

# Claude Code worktree scaffolding
.claude/

# macOS Finder metadata
.DS_Store
