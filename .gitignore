# Python virtualenv (large, regenerable from rl/uv.lock)
rl/.venv/

# Python caches
__pycache__/
*.pyc

# pufferlib resource symlinks that point into .venv
/resources
/rl/resources
/rl/iphone_data/resources

# Generated/regenerable artifacts (fitted weights, logs)
rl/*.npy
rl/*.log
rl/*.pt

# iPhone-capture artifacts — screenshots/captures are debug output;
# ocr/tap/wininfo are binaries built from the *.swift sources via build.sh
rl/iphone_data/captures/
rl/iphone_data/runs/
rl/iphone_data/*.png
rl/iphone_data/ocr
rl/iphone_data/ocrserve
rl/iphone_data/tap
rl/iphone_data/wininfo

# compiled native MCTS binary (and ad-hoc experiment build variants)
c/nw
c/nw[0-9]*
c/nw_agg

# compiled C hot-path shared lib (built from rl/fast_engine.c)
rl/fast_engine.so

# generated HTML (regenerable from gen_play_html.py / gen_botdiff_html.py)
rl/play_sim.html
rl/iphone_data/botdiff.html

# iPhone-Mirroring window-geometry cache (machine-local)
rl/iphone_data/.wincache

# Claude Code worktree scaffolding
.claude/
